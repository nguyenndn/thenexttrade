# Example Environment Variables for TheNextTrade
# Copy this file to .env.local and fill in actual values
# NEVER commit real secrets to git — use Vercel Dashboard for production

# Database (Supabase)
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/database"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App URL
NEXT_PUBLIC_APP_URL="https://thenexttrade.vercel.app"

# Redis (Upstash REST API)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Email (Resend SMTP)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="re_your_resend_api_key"
SMTP_SECURE="false"
SMTP_FROM_EMAIL="onboarding@resend.dev"
SMTP_FROM_NAME="The Next Trade"

# AI Services (Optional)
GEMINI_API_KEY="your-gemini-api-key"
# GITHUB_TOKEN="ghp_your_github_token"

# Vercel Cron (auto-injected by Vercel, or set manually)
# CRON_SECRET="your-random-secret"

# Node Environment
NODE_ENV="development"
