# Example Environment Variables for TheNextTrade
# Copy this file to .env.local or .env.production and update values

# Database
DATABASE_URL="postgresql://username:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://username:password@host:5432/database"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App URL
NEXT_PUBLIC_APP_URL="https://thenexttrade.vercel.app"

# Redis (Upstash REST API)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-pass"
SMTP_SECURE="false"
SMTP_FROM_EMAIL="noreply@thenexttrade.com"
SMTP_FROM_NAME="The Next Trade"

# AI Services (Optional)
GEMINI_API_KEY="your-gemini-api-key"
# GITHUB_TOKEN="ghp_your_github_token"

# Node Environment
NODE_ENV="development"
