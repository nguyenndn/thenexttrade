{
  "name": "gsn-crm",
  "version": "1.0.0",
  "description": "Web app giáo dục và hỗ trợ phân tích forex với hệ thống học liệu, quiz, trading journal, risk calculator và performance dashboard.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run env:local && next dev",
    "dev:prod": "npm run env:prod && next dev",
    "build": "next build",
    "build:local": "npm run env:local && next build",
    "build:prod": "npm run env:prod && next build",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "test": "vitest",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "verify": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/verify-routes.ts",
    "worker": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/worker.ts",
    "env:local": "powershell -ExecutionPolicy Bypass -File ./scripts/switch-env.ps1 local",
    "env:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/switch-env.ps1 production",
    "db:migrate": "dotenv -e .env -- prisma migrate deploy",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:studio": "dotenv -e .env -- prisma studio",
    "perf:test": "dotenv -e .env -- tsx scripts/measure-performance.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
